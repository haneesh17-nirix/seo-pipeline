# Your website
SITE_URL=https://www.nyrix.aazhara.in

# Ollama server — set to localhost if running locally, or your Azure VM IP
OLLAMA_HOST=http://localhost:11434
# LLM model to use (pulled during VM setup)
OLLAMA_MODEL=llama3.2

# Google Search Console API
# Path to the service account JSON key file (see docs/gsc-setup.md)
GSC_CREDENTIALS_FILE=./gsc-credentials.json
# The exact property URL as registered in GSC (include https://)
GSC_SITE_URL=https://www.nyrix.aazhara.in

# Target country for filtering GSC data (e.g. us, in, gb, au)
TARGET_COUNTRY=in
