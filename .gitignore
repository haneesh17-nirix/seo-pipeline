node_modules/
dist/
.env
*.env.local

# Runtime output — tracked dirs but not contents
data/*
!data/.gitkeep
output/*
!output/.gitkeep
reports/*
!reports/.gitkeep
logs/*
!logs/.gitkeep

# Secrets
infra/.deploy-state.json
gsc-credentials.json
brands/*/gsc-credentials.json
*.pem
*.key

# Brand output dirs (tracked dirs but not contents)
brands/*/output/*
brands/*/reports/*
brands/*/logs/*
!brands/*/output/.gitkeep
!brands/*/reports/.gitkeep
!brands/*/logs/.gitkeep
